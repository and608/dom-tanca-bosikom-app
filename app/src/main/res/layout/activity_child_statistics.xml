<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@android:color/transparent" />

        <TextView
            android:id="@+id/textHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Статистика ребёнка"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical" />
    </LinearLayout>

    <TextView
        android:id="@+id/textTotalClasses"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Всего отмеченных занятий: 0"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textPresentCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Присутствовал: 0"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textAbsentCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Отсутствовал: 0"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textSickCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Болел: 0"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textAttendancePercent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Процент посещаемости: 0%"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="#EEEEEE" />

</LinearLayout>