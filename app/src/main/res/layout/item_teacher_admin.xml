<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/textTeacherName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Имя преподавателя"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#222222" />

    <TextView
        android:id="@+id/textTeacherEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="email@example.com"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/textTeacherPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+7..."
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/textTeacherGroups"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Группы: не назначены"
        android:textSize="14sp"
        android:textColor="#444444"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/buttonDeleteTeacher"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Удалить" />
    </LinearLayout>

</LinearLayout>