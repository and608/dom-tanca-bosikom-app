<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1976D2"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textScreenTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Кабинет родителя"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textViewWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Добро пожаловать!"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/buttonLogout"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFF"
            android:contentDescription="Выход" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/buttonMyChildren"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👶 Мои дети"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#1976D2" />

        <Button
            android:id="@+id/buttonAttendance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Посещаемость"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#1976D2" />

        <Button
            android:id="@+id/buttonSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 Расписание занятий"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#1976D2" />

        <Button
            android:id="@+id/buttonAddChild"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="➕ Добавить ребёнка"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#4CAF50" />

        <Button
            android:id="@+id/btnNews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Новости" />

    </LinearLayout>

</LinearLayout>