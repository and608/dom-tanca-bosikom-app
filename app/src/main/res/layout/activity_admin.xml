<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="#F5F5F5">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:padding="20dp">

		<!-- Шапка -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:background="#1976D2"
			android:padding="20dp"
			android:layout_marginBottom="20dp"
			android:backgroundTint="#1976D2">

			<TextView
				android:id="@+id/textAdminTitle"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Кабинет руководителя"
				android:textColor="#FFFFFF"
				android:textSize="24sp"
				android:textStyle="bold" />

			<TextView
				android:id="@+id/textAdminWelcome"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Добро пожаловать!"
				android:textColor="#E3F2FD"
				android:textSize="16sp"
				android:layout_marginTop="6dp" />
		</LinearLayout>

		<!-- Первая строка -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_marginBottom="16dp">

			<LinearLayout
				android:id="@+id/cardGroups"
				android:layout_width="0dp"
				android:layout_height="130dp"
				android:layout_weight="1"
				android:orientation="vertical"
				android:background="#FFFFFF"
				android:padding="16dp"
				android:layout_marginEnd="8dp"
				android:gravity="center"
				android:clickable="true"
				android:focusable="true">

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="👥"
					android:textSize="28sp" />

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Группы"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="#222222"
					android:layout_marginTop="8dp" />
			</LinearLayout>

			<LinearLayout
				android:id="@+id/cardTeachers"
				android:layout_width="0dp"
				android:layout_height="130dp"
				android:layout_weight="1"
				android:orientation="vertical"
				android:background="#FFFFFF"
				android:padding="16dp"
				android:layout_marginStart="8dp"
				android:gravity="center"
				android:clickable="true"
				android:focusable="true">

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="🎓"
					android:textSize="28sp" />

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Преподаватели"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="#222222"
					android:gravity="center"
					android:layout_marginTop="8dp" />
			</LinearLayout>
		</LinearLayout>

		<!-- Вторая строка -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_marginBottom="16dp">

			<LinearLayout
				android:id="@+id/cardParents"
				android:layout_width="0dp"
				android:layout_height="130dp"
				android:layout_weight="1"
				android:orientation="vertical"
				android:background="#FFFFFF"
				android:padding="16dp"
				android:layout_marginEnd="8dp"
				android:gravity="center"
				android:clickable="true"
				android:focusable="true">

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="👨‍👩‍👧"
					android:textSize="28sp" />

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Родители"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="#222222"
					android:layout_marginTop="8dp" />
			</LinearLayout>

			<LinearLayout
				android:id="@+id/cardNews"
				android:layout_width="0dp"
				android:layout_height="130dp"
				android:layout_weight="1"
				android:orientation="vertical"
				android:background="#FFFFFF"
				android:padding="16dp"
				android:layout_marginStart="8dp"
				android:gravity="center"
				android:clickable="true"
				android:focusable="true">

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="📰"
					android:textSize="28sp" />

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Новости"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="#222222"
					android:layout_marginTop="8dp" />
			</LinearLayout>
		</LinearLayout>

		<!-- Третья строка -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal">

			<LinearLayout
				android:id="@+id/cardPayments"
				android:layout_width="0dp"
				android:layout_height="130dp"
				android:layout_weight="1"
				android:orientation="vertical"
				android:background="#FFFFFF"
				android:padding="16dp"
				android:layout_marginEnd="8dp"
				android:gravity="center"
				android:clickable="true"
				android:focusable="true">

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="💳"
					android:textSize="28sp" />

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Оплаты"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="#222222"
					android:layout_marginTop="8dp" />
			</LinearLayout>

			<LinearLayout
				android:id="@+id/cardLogout"
				android:layout_width="0dp"
				android:layout_height="130dp"
				android:layout_weight="1"
				android:orientation="vertical"
				android:background="#FFFFFF"
				android:padding="16dp"
				android:layout_marginStart="8dp"
				android:gravity="center"
				android:clickable="true"
				android:focusable="true">

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="🚪"
					android:textSize="28sp" />

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Выход"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="#D32F2F"
					android:layout_marginTop="8dp" />
			</LinearLayout>
		</LinearLayout>

	</LinearLayout>
</ScrollView>